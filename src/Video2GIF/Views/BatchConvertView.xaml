<UserControl x:Class="Video2GIF.Views.BatchConvertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Video2GIF.ViewModels"
             xmlns:m="clr-namespace:Video2GIF.Models">

    <!-- 资源定义 -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- 文件状态转颜色 -->
        <Style x:Key="StatusTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 主内容区域 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：视频预览 + 文件列表 -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="200" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="120" MaxHeight="250" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 视频预览区 -->
                    <Border Grid.Row="0" CornerRadius="8" Background="#FF1E293B" ClipToBounds="True">
                        <Grid>
                            <!-- MediaElement 视频播放器 -->
                            <MediaElement x:Name="mediaPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Stop"
                                          MediaOpened="MediaPlayer_MediaOpened"
                                          MediaEnded="MediaPlayer_MediaEnded"
                                          Source="{Binding VideoSource}"
                                          Stretch="Uniform" />

                            <!-- 无预览提示 -->
                            <TextBlock Text="请选择文件以预览视频"
                                       FontSize="14"
                                       Foreground="#66FFFFFF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasVideoSource}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- 控制栏 -->
                    <Border Grid.Row="1" Padding="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 播放控制按钮 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="▶" Command="{Binding PlayCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,6" FontSize="14" Margin="0,0,4,0" />
                                <Button Content="⏸" Command="{Binding PauseCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,6" FontSize="14" Margin="0,0,4,0" />
                                <Button Content="⏹" Command="{Binding StopCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,6" FontSize="14" />
                            </StackPanel>

                            <!-- 进度条 -->
                            <Slider Grid.Column="1"
                                    x:Name="progressSlider"
                                    Minimum="0"
                                    Value="{Binding CurrentPosition, Mode=TwoWay}"
                                    ValueChanged="ProgressSlider_ValueChanged"
                                    Thumb.DragStarted="ProgressSlider_MouseLeftButtonDown"
                                    Thumb.DragCompleted="ProgressSlider_MouseLeftButtonUp"
                                    VerticalAlignment="Center"
                                    Margin="12,0"
                                    Style="{StaticResource ModernSlider}" />

                            <!-- 时间显示 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PositionText}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text=" / "
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DurationText}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 视频信息 -->
                    <Border Grid.Row="2" Padding="0,8,0,0">
                        <TextBlock Text="{Binding VideoInfoText}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                    </Border>

                    <!-- 文件列表 -->
                    <Border Grid.Row="3" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="文件列表"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8" />

                            <ListView Grid.Row="1"
                                      x:Name="fileListView"
                                      ItemsSource="{Binding FileItems}"
                                      SelectedItem="{Binding SelectedFileItem, Mode=TwoWay}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      Background="{StaticResource BackgroundBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      Padding="4">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="文件名" Width="220">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="状态" Width="140">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <!-- 等待：灰色 -->
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StatusTextBlock}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Waiting">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Converting">
                                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Done">
                                                                            <Setter Property="Foreground" Value="#FF4CAF50" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                            <Setter Property="Foreground" Value="#FFE53935" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="" Width="60">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="删除"
                                                            Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Padding="6,2"
                                                            FontSize="11"
                                                            HorizontalAlignment="Center" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- 添加文件/清空列表按钮 -->
                    <Border Grid.Row="4" Padding="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="添加文件"
                                    Command="{Binding AddFilesCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,6" FontSize="12"
                                    Margin="0,0,8,0" />
                            <Button Content="清空列表"
                                    Command="{Binding ClearFilesCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,6" FontSize="12" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧：设置面板 -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 标题 -->
                        <TextBlock Text="转换设置"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16" />

                        <!-- 输出分辨率 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="输出分辨率" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Settings.OutputWidth, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" />
                                <TextBlock Grid.Column="1"
                                           Text="×"
                                           FontSize="16"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Settings.OutputHeight, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox IsChecked="{Binding Settings.LockAspectRatio}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="锁定宽高比"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 帧率 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Style="{StaticResource FieldLabel}">
                                <Run Text="帧率 (FPS)" />
                                <Run Text="{Binding Settings.FrameRate, StringFormat='  {0}'}"
                                     Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Minimum="1" Maximum="30"
                                    Value="{Binding Settings.FrameRate}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Style="{StaticResource ModernSlider}" />
                            <Grid>
                                <TextBlock Text="1" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="15" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="30" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>

                        <!-- 播放速度 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="播放速度" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding SpeedOptions}"
                                      SelectedItem="{Binding Settings.Speed}"
                                      Style="{StaticResource ModernComboBox}" />
                        </StackPanel>

                        <!-- 色彩处理 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="色彩处理" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding DitherOptions}"
                                      SelectedValue="{Binding Settings.DitherAlgorithm}"
                                      SelectedValuePath="Value"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Label, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" — " Foreground="{StaticResource TextTertiaryBrush}" />
                                            <Run Text="{Binding Desc, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- 调色板模式 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="调色板模式" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding StatsModeOptions}"
                                      SelectedValue="{Binding Settings.PaletteStatsMode}"
                                      SelectedValuePath="Value"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Label, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" — " Foreground="{StaticResource TextTertiaryBrush}" />
                                            <Run Text="{Binding Desc, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- 分隔线 -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16" />

                        <!-- 输出目录 -->
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="输出目录" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="0,0,8,0"
                                         Tag="留空则输出到视频同目录" />
                                <Button Grid.Column="1"
                                        Content="浏览"
                                        Command="{Binding SelectOutputFolderCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8" FontSize="12" />
                            </Grid>
                            <TextBlock Text="留空则输出到每个视频的同目录下，命名方式：原视频名.gif"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部：批量转换按钮和进度 -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 批量转换按钮 -->
                <Button Grid.Column="0"
                        Content="🚀 批量转换"
                        Command="{Binding StartBatchConvertCommand}"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="15"
                        Padding="32,12" />

                <!-- 进度区域 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{Binding BatchStatusText}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding BatchProgress, StringFormat={}{0:F1}%}"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <ProgressBar Value="{Binding BatchProgress}"
                                 Maximum="100"
                                 Height="6"
                                 Background="{StaticResource BorderBrush}"
                                 Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>

                <!-- 取消按钮 -->
                <Button Grid.Column="2"
                        Content="取消"
                        Command="{Binding CancelBatchConvertCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibilityConverter}}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
