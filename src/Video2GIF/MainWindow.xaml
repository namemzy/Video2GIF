<Window x:Class="Video2GIF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Video2GIF.ViewModels"
        Title="Video2GIF - 视频转GIF工具"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource DefaultFont}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <!-- 资源定义必须在使用之前 -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎬 Video2GIF"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="视频转GIF工具"
                           FontSize="13"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- 左侧：视频预览区域 -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 视频预览区 -->
                    <Border Grid.Row="0" CornerRadius="8" Background="#FF1E293B" ClipToBounds="True">
                        <Grid>
                            <!-- MediaElement 视频播放器 -->
                            <MediaElement x:Name="mediaPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Stop"
                                          MediaOpened="MediaPlayer_MediaOpened"
                                          MediaEnded="MediaPlayer_MediaEnded"
                                          Source="{Binding VideoSource}"
                                          Stretch="Uniform" />

                            <!-- 拖拽提示覆盖层 -->
                            <Border x:Name="dropOverlay"
                                    Background="#CC1E293B"
                                    Visibility="{Binding ShowDropHint, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📁"
                                               FontSize="48"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,12" />
                                    <TextBlock Text="拖拽视频文件到此处"
                                               FontSize="16"
                                               FontWeight="Medium"
                                               Foreground="#99FFFFFF"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="或点击下方按钮打开文件"
                                               FontSize="12"
                                               Foreground="#66FFFFFF"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 控制栏 -->
                    <Border Grid.Row="1" Padding="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 播放控制按钮 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="▶" Command="{Binding PlayCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,6" FontSize="14" Margin="0,0,4,0" />
                                <Button Content="⏸" Command="{Binding PauseCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,6" FontSize="14" Margin="0,0,4,0" />
                                <Button Content="⏹" Command="{Binding StopCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,6" FontSize="14" />
                            </StackPanel>

                            <!-- 进度条 -->
                            <Slider Grid.Column="1"
                                    x:Name="progressSlider"
                                    Minimum="0"
                                    Maximum="{Binding Settings.TotalDuration}"
                                    Value="{Binding CurrentPosition, Mode=TwoWay}"
                                    ValueChanged="ProgressSlider_ValueChanged"
                                    Thumb.DragStarted="ProgressSlider_MouseLeftButtonDown"
                                    Thumb.DragCompleted="ProgressSlider_MouseLeftButtonUp"
                                    VerticalAlignment="Center"
                                    Margin="12,0"
                                    Style="{StaticResource ModernSlider}" />

                            <!-- 时间显示 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding PositionText}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text=" / "
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding DurationText}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 视频信息 -->
                    <Border Grid.Row="2" Padding="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding VideoInfoText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                            <!-- 打开文件 + 时间控制 -->
                            <StackPanel Margin="0,8,0,0">
                                <Button Content="打开文件"
                                        Command="{Binding OpenFileCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="12,6" FontSize="12" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Content="设为起点"
                                            Command="{Binding SetStartTimeCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,6" FontSize="12"
                                            Margin="0,0,6,0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.StartTime, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                             Style="{StaticResource ModernTextBox}"
                                             Margin="0,0,12,0" />
                                    <Button Grid.Column="2"
                                            Content="设为终点"
                                            Command="{Binding SetEndTimeCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="12,6" FontSize="12"
                                            Margin="0,0,6,0" />
                                    <TextBox Grid.Column="3"
                                             Text="{Binding Settings.EndTime, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                             Style="{StaticResource ModernTextBox}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧：设置面板 -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 标题 -->
                        <TextBlock Text="转换设置"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16" />

                        <!-- FFmpeg 路径 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="FFmpeg 路径" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Settings.FFmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="1"
                                        Content="浏览"
                                        Command="{Binding SelectFFmpegPathCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8" FontSize="12" />
                            </Grid>
                        </StackPanel>

                        <!-- 分隔线 -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16" />

                        <!-- 输出分辨率 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="输出分辨率" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Settings.OutputWidth, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" />
                                <TextBlock Grid.Column="1"
                                           Text="×"
                                           FontSize="16"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding Settings.OutputHeight, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" />
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox IsChecked="{Binding Settings.LockAspectRatio}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="锁定宽高比"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 帧率 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Style="{StaticResource FieldLabel}">
                                <Run Text="帧率 (FPS)" />
                                <Run Text="{Binding Settings.FrameRate, StringFormat='  {0}'}"
                                     Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Slider Minimum="1" Maximum="30"
                                    Value="{Binding Settings.FrameRate}"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Style="{StaticResource ModernSlider}" />
                            <Grid>
                                <TextBlock Text="1" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" />
                                <TextBlock Text="15" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="30" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </StackPanel>

                        <!-- 播放速度 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="播放速度" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding SpeedOptions}"
                                      SelectedItem="{Binding Settings.Speed}"
                                      Style="{StaticResource ModernComboBox}" />
                        </StackPanel>

                        <!-- 抖动算法 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="抖动算法" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding DitherOptions}"
                                      SelectedValue="{Binding Settings.DitherAlgorithm}"
                                      SelectedValuePath="Value"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Label, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" — " Foreground="{StaticResource TextTertiaryBrush}" />
                                            <Run Text="{Binding Desc, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- 调色板模式 -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="调色板模式" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding StatsModeOptions}"
                                      SelectedValue="{Binding Settings.PaletteStatsMode}"
                                      SelectedValuePath="Value"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <Run Text="{Binding Label, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" — " Foreground="{StaticResource TextTertiaryBrush}" />
                                            <Run Text="{Binding Desc, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <!-- 分隔线 -->
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16" />

                        <!-- 输出路径 -->
                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="输出路径" Style="{StaticResource FieldLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Settings.OutputFilePath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}"
                                         Margin="0,0,8,0" />
                                <Button Grid.Column="1"
                                        Content="浏览"
                                        Command="{Binding SelectOutputPathCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,8" FontSize="12" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部：转换按钮和进度 -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 转换按钮 -->
                <Button Grid.Column="0"
                        Content="🚀 开始转换"
                        Command="{Binding ConvertCommand}"
                        Style="{StaticResource PrimaryButton}"
                        FontSize="15"
                        Padding="32,12" />

                <!-- 进度区域 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{Binding ConvertStatusText}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ConvertProgress, StringFormat={}{0:F1}%}"
                                   FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                    </Grid>
                    <ProgressBar Value="{Binding ConvertProgress}"
                                 Maximum="100"
                                 Height="6"
                                 Background="{StaticResource BorderBrush}"
                                 Foreground="{StaticResource PrimaryBrush}" />
                </StackPanel>

                <!-- 取消按钮 -->
                <Button Grid.Column="2"
                        Content="取消"
                        Command="{Binding CancelConvertCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Visibility="{Binding IsConverting, Converter={StaticResource BoolToVisibilityConverter}}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>

</Window>
